! pw.x input generated by material-identifier
! formula:        TiO2
! name:           Titanium Dioxide (Rutile)
! space group:    P4_2/mnm (#136)
! crystal system: tetragonal
! source:         LLM-inferred (confidence: high)
! electronic:     insulator/semiconductor — fixed occupations
!
! Pseudopotentials follow the SSSP Efficiency v1.3 naming
! convention. Provide the UPF files via pseudo_dir.
! Cutoffs and k-points are starting values — converge for production.
&CONTROL
  calculation = 'scf'
  prefix      = 'TiO2'
  pseudo_dir  = './pseudos/'
  outdir      = './out/'
  verbosity   = 'high'
  tprnfor     = .true.
  tstress     = .true.
/
&SYSTEM
  ibrav       = 0
  nat         = 6
  ntyp        = 2
  ecutwfc     = 50
  ecutrho     = 400
  occupations = 'fixed'
/
&ELECTRONS
  conv_thr    = 1.0e-08
  mixing_beta = 0.4
/

ATOMIC_SPECIES
  Ti     47.8670  Ti.pbe-spn-kjpaw_psl.1.0.0.UPF
  O      15.9990  O.pbe-n-kjpaw_psl.0.1.UPF

CELL_PARAMETERS angstrom
     4.502120000    0.000000000    0.000000000
     0.000000000    4.502120000    0.000000000
     0.000000000    0.000000000    2.898840000

ATOMIC_POSITIONS crystal
  Ti    0.00000000   0.00000000   0.00000000
  Ti    0.50000000   0.50000000   0.50000000
  O     0.30500000   0.30500000   0.00000000
  O     0.69500000   0.69500000   0.00000000
  O     0.19500000   0.80500000   0.50000000
  O     0.80500000   0.19500000   0.50000000

K_POINTS automatic
  7 7 11  0 0 0
