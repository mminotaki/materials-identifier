! pw.x input generated by material-identifier
! formula:        Si
! name:           Silicon
! space group:    Fd-3m (#227)
! crystal system: cubic
! source:         LLM-inferred (confidence: high)
! electronic:     insulator/semiconductor — fixed occupations
!
! Pseudopotentials follow the SSSP Efficiency v1.3 naming
! convention. Provide the UPF files via pseudo_dir.
! Cutoffs and k-points are starting values — converge for production.
&CONTROL
  calculation = 'scf'
  prefix      = 'Si'
  pseudo_dir  = './pseudos/'
  outdir      = './out/'
  verbosity   = 'high'
  tprnfor     = .true.
  tstress     = .true.
/
&SYSTEM
  ibrav       = 0
  nat         = 2
  ntyp        = 1
  ecutwfc     = 30
  ecutrho     = 240
  occupations = 'fixed'
/
&ELECTRONS
  conv_thr    = 1.0e-08
  mixing_beta = 0.4
/

ATOMIC_SPECIES
  Si     28.0850  Si.pbe-n-rrkjus_psl.1.0.0.UPF

CELL_PARAMETERS angstrom
     5.322380000    0.000000000    0.000000000
     0.000000000    5.322380000    0.000000000
     0.000000000    0.000000000    5.322380000

ATOMIC_POSITIONS crystal
  Si    0.00000000   0.00000000   0.00000000
  Si    0.25000000   0.25000000   0.25000000

K_POINTS automatic
  6 6 6  0 0 0
